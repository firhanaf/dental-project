# ── Server ──────────────────────────────────
PORT=8080
APP_ENV=development

# ── Database ─────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=dentaldb
DB_USER=dental
DB_PASSWORD=ganti_dengan_password_kuat
DB_SSLMODE=disable

# ── JWT ──────────────────────────────────────
# Generate dengan: openssl rand -base64 64
JWT_SECRET=ganti_dengan_random_string_minimal_64_karakter_xxxxxxxxxxxxxxxxx
JWT_EXPIRE_HOURS=8

# ── Storage ──────────────────────────────────
UPLOAD_DIR=/uploads
