# ── Server ───────────────────────────────────
PORT=8080
APP_ENV=development

# ── Database ─────────────────────────────────
# LOCAL DEV  → DB_HOST=localhost  (pakai make dev-up)
# PRODUCTION → DB_HOST=postgres   (docker-compose.yml override otomatis)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dentaldb
DB_USER=dental
DB_PASSWORD=ganti_dengan_password_kuat
DB_SSLMODE=disable

# ── JWT ──────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=ganti_dengan_random_string_minimal_64_karakter_xxxxxxxxxxxxxxxxx
JWT_EXPIRE_HOURS=8

# ── Storage ──────────────────────────────────
# PRODUCTION → wajib /uploads (absolut, sesuai docker volume)
# LOCAL DEV  → bisa ./uploads (relatif) asal folder sudah dibuat
UPLOAD_DIR=/uploads
MAX_FILE_SIZE_MB=20
