# ── Server ───────────────────────────────────────────────────
PORT=8080
APP_ENV=production

# ── Database ─────────────────────────────────────────────────
# DB_HOST selalu dioverride ke "postgres" oleh docker-compose
DB_HOST=postgres
DB_PORT=5432
DB_NAME=dentaldb
DB_USER=dental
DB_PASSWORD=GANTI_PASSWORD_KUAT_DI_SINI
DB_SSLMODE=disable

# ── JWT ──────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=GANTI_DENGAN_RANDOM_STRING_MIN_64_KARAKTER
JWT_EXPIRE_HOURS=8

# ── Storage ──────────────────────────────────────────────────
UPLOAD_DIR=/uploads
MAX_FILE_SIZE_MB=20
